{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task State (v2.1 \u00a778-7 / Appendix A)",
  "type": "object",
  "required": [
    "task_id",
    "state",
    "history"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "state": {
      "enum": [
        "INTAKE",
        "DISCOVERY",
        "REQUIREMENTS",
        "DESIGN",
        "DELIVERY_PLAN",
        "IMPLEMENTATION",
        "QUALITY_REVIEW",
        "REMEDIATION",
        "SECURITY_REVIEW",
        "PRIVACY_COMPLIANCE_REVIEW",
        "PRODUCTION_READINESS",
        "PRODUCT_ACCEPTANCE",
        "HUMAN_RELEASE_AUTHORIZATION",
        "DEPLOYMENT",
        "PRODUCTION_VERIFICATION",
        "OPERATIONS_AND_FEEDBACK",
        "BLOCKED",
        "CLOSED"
      ]
    },
    "run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "iteration_count": {
      "type": "integer"
    },
    "rejection_cycles": {
      "type": "integer"
    },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "at",
          "from",
          "to",
          "evidence"
        ],
        "properties": {
          "at": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    }
  }
}
