{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Memory Record Front Matter (v2 \u00a728 / v2.1 \u00a783.2)",
  "type": "object",
  "required": [
    "memory_id",
    "namespace",
    "type",
    "subject",
    "source",
    "creator",
    "confidence",
    "sensitivity",
    "created",
    "updated",
    "retention"
  ],
  "properties": {
    "memory_id": {
      "type": "string",
      "pattern": "^MEM-(ORG|[A-Z]{2,3})-[0-9]{4,}$"
    },
    "namespace": {
      "type": "string",
      "pattern": "^(org|roles/(pjm|saa|uud|sde|sat|sse|dpc|dce|de|aie|tw|ale|lin))$"
    },
    "type": {
      "enum": ["user_provided", "observed", "inferred", "generated"]
    },
    "subject": {
      "type": "string",
      "minLength": 3
    },
    "scope": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "minLength": 3
    },
    "creator": {
      "type": "string"
    },
    "confidence": {
      "enum": ["verified", "high", "medium", "low", "uncertain"]
    },
    "sensitivity": {
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "created": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "updated": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "expires": {
      "type": ["string", "null"]
    },
    "retention": {
      "type": "string",
      "minLength": 3
    },
    "supersedes": {
      "type": ["string", "null"]
    },
    "superseded_by": {
      "type": ["string", "null"]
    },
    "related": {
      "type": "array",
      "items": {"type": "string"}
    },
    "tombstone": {
      "type": "boolean"
    },
    "purged_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "purge_reason": {
      "type": "string",
      "minLength": 3
    }
  },
  "if": {"properties": {"tombstone": {"const": true}}, "required": ["tombstone"]},
  "then": {"required": ["purged_at", "purge_reason"]}
}
