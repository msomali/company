{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gate Decision Record (v2 \u00a78)",
  "type": "object",
  "required": [
    "gate_id",
    "artifact_or_release",
    "gate_owner",
    "decision",
    "criteria_version",
    "evidence",
    "next_owner",
    "decided_at"
  ],
  "properties": {
    "gate_id": {
      "type": "string"
    },
    "artifact_or_release": {
      "type": "string"
    },
    "gate_owner": {
      "enum": [
        "SAT",
        "SSE",
        "DPC",
        "DCE",
        "PJM",
        "HUMAN"
      ]
    },
    "decision": {
      "enum": [
        "APPROVED",
        "APPROVED_WITH_CONDITIONS",
        "CHANGES_REQUIRED",
        "REJECTED"
      ]
    },
    "criteria_version": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expires": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_owner": {
      "type": "string"
    },
    "decided_at": {
      "type": "string"
    },
    "approval_message_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
